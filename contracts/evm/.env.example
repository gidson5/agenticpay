# =====================================================================
# AgenticPay EVM contracts — environment variables
# Copy to .env and fill the values you need. `hardhat.config.ts` picks
# these up at runtime; anything omitted falls back to a safe default or
# the hardhat-network.
# =====================================================================

# ── Signer key used by every `hardhat run` script (never commit).
DEPLOYER_PRIVATE_KEY=

# ── RPC endpoints. Only the networks you actually target need values.
MAINNET_RPC_URL=
SEPOLIA_RPC_URL=
POLYGON_RPC_URL=
POLYGON_AMOY_RPC_URL=
ARBITRUM_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
OPTIMISM_RPC_URL=
OPTIMISM_SEPOLIA_RPC_URL=
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# ── Block-explorer verification. Since Etherscan v2 is a unified API
# you only need ETHERSCAN_API_KEY for all chains Etherscan supports.
# Fill the others only when using non-Etherscan explorers.
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# ── CREATE2 factory address (defaults to the canonical ImmutableCreate2
# factory from 0age when unset). Override per-network if you run your own.
CREATE2_FACTORY_ADDRESS=

# ── Gnosis Safe integration (optional). Required only for
# scripts/propose-safe-upgrade.ts.
SAFE_ADDRESS=
SAFE_SERVICE_URL=
SAFE_SIGNER_PRIVATE_KEY=

# ── Gas reporter (enables gas column in `npm test`).
REPORT_GAS=false
COINMARKETCAP_API_KEY=
